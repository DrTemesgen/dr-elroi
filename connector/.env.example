# Dr. Elroi — environment template. COPY this to connector/.env and fill in real values.
#   cp connector/.env.example connector/.env   (then edit)
# connector/.env is git-ignored and holds the real secrets. Never commit it.

# Medplum API base URL
MEDPLUM_URL=http://localhost:8103

# Medplum client-credentials application (create one in the Medplum admin UI).
# Used by the connector and by seed-sample-data.py / fix-references.py.
MEDPLUM_CLIENT_ID=your-medplum-client-id
MEDPLUM_CLIENT_SECRET=your-medplum-client-secret

# The clinic project that connector logins are pinned to (a normal, project-scoped Medplum project,
# NOT the super-admin project — so patient logins and multi-tenant scoping work).
ELROI_PROJECT_ID=your-project-id

# Local AI services
OLLAMA_URL=http://127.0.0.1:11434
ELROI_MODEL=alibayram/medgemma:4b

# Admin login used by the loader/seed scripts (load-icd10cm, deploy-spaces-bots, *-care-templates).
ELROI_EMAIL=admin@example.com
ELROI_PASSWORD=change-me
